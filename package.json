{
  "name": "ollamacommit",
  "displayName": "Ollama Commit Message",
  "description": "Generate Git commit messages in VS Code using a local Ollama server.",
  "version": "0.4.0",
  "publisher": "linkdata",
  "icon": "media/ollama-commit-title.png",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/linkdata/Ollama-Commit.git"
  },
  "homepage": "https://github.com/linkdata/Ollama-Commit#readme",
  "bugs": {
    "url": "https://github.com/linkdata/Ollama-Commit/issues"
  },
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "SCM Providers",
    "Other"
  ],
  "galleryBanner": {
    "color": "#0f172a",
    "theme": "dark"
  },
  "keywords": [
    "ollama",
    "git",
    "commit",
    "commit message",
    "source control",
    "conventional commits",
    "ai",
    "llm"
  ],
  "activationEvents": [
    "onCommand:ollamacommit.generateCommit",
    "onCommand:ollamacommit.openSettings"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "ollamacommit.generateCommit",
        "title": "Ollama Commit: Generate Commit Message",
        "category": "Ollama Commit",
        "icon": {
          "light": "media/source-control-icon.png",
          "dark": "media/source-control-icon.png"
        }
      },
      {
        "command": "ollamacommit.openSettings",
        "title": "Ollama Commit: Open Settings Page",
        "category": "Ollama Commit",
        "icon": {
          "light": "media/settings-light.svg",
          "dark": "media/settings-dark.svg"
        }
      }
    ],
    "menus": {
      "scm/title": [
        {
          "command": "ollamacommit.generateCommit",
          "group": "navigation@-100",
          "when": "scmProvider == git"
        }
      ]
    },
    "configuration": {
      "title": "Ollama Commit",
      "properties": {
        "ollamacommit.baseUrl": {
          "type": "string",
          "default": "http://127.0.0.1:11434",
          "description": "Base URL for the Ollama server. In WSL the extension will also try Windows host fallbacks automatically."
        },
        "ollamacommit.model": {
          "type": "string",
          "default": "qwen3-coder-next:latest",
          "description": "Ollama model to use for generating commit messages."
        },
        "ollamacommit.keepAlive": {
          "type": "number",
          "default": 0,
          "minimum": 0,
          "description": "Optional keep_alive value passed to Ollama chat requests. Set to 0 to omit keep_alive."
        },
        "ollamacommit.systemPrompt": {
          "type": "string",
          "default": "You are an assistant that writes concise, clear, professional git commit messages based on staged diff.\nPrefer conventional commits.\nDo not output any thinking, reasoning, analysis, or XML-style thinking tags.\nReturn only the final commit message.",
          "markdownDescription": "System prompt sent to Ollama before the staged diff."
        },
        "ollamacommit.enableThinking": {
          "type": "boolean",
          "default": false,
          "description": "Allow supported models to use thinking/reasoning mode internally before returning the final commit message."
        },
        "ollamacommit.maxDiffChars": {
          "type": "number",
          "default": 12000,
          "minimum": 1000,
          "description": "Maximum number of staged diff characters sent to the model."
        },
        "ollamacommit.temperature": {
          "type": "number",
          "default": 0.2,
          "minimum": 0,
          "maximum": 2,
          "description": "Sampling temperature passed to Ollama."
        },
        "ollamacommit.copyToClipboard": {
          "type": "boolean",
          "default": false,
          "description": "Also copy the generated commit message to the clipboard."
        }
      }
    }
  },
  "scripts": {
    "build": "tsc -p .",
    "compile": "npm run build",
    "watch": "tsc -w -p .",
    "vscode:prepublish": "npm run build",
    "package": "vsce package --no-dependencies --no-rewrite-relative-links",
    "publish:marketplace": "vsce publish --no-dependencies"
  },
  "devDependencies": {
    "@types/node": "^22.13.14",
    "@types/vscode": "^1.90.0",
    "@vscode/vsce": "^3.2.2",
    "typescript": "^5.8.2"
  }
}
